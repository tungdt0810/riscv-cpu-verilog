// Setup registers:
//   x1 = 7   (0x00000007)
//   x2 = -3  (0xFFFFFFFD)
//   x3 = 3   (shift amount)
//
// ── Section 1: Setup ─────────────────────────────────────────────────────────
// 0x000  00700093  addi  x1,  x0,   7          x1 = 7
// 0x004  FFD00113  addi  x2,  x0,  -3          x2 = 0xFFFFFFFD
// 0x008  00300193  addi  x3,  x0,   3          x3 = 3
//
// ── Section 2: R-type (all 10) ───────────────────────────────────────────────
// Note: rd=x27 to keep x4 free for hazard and sub-word tests.
// 0x00C  00208DB3  add   x27, x1,  x2          x27= 7+(-3)  = 4
// 0x010  402082B3  sub   x5,  x1,  x2          x5 = 7-(-3)  = 10  (0x0A)
// 0x014  0020F333  and   x6,  x1,  x2          x6 = 7&(-3)  = 5   (0x05)
// 0x018  0020E3B3  or    x7,  x1,  x2          x7 = 7|(-3)  = 0xFFFFFFFF
// 0x01C  0020C433  xor   x8,  x1,  x2          x8 = 7^(-3)  = 0xFFFFFFFA
// 0x020  003094B3  sll   x9,  x1,  x3          x9 = 7<<3    = 56  (0x38)
// 0x024  00315533  srl   x10, x2,  x3          x10= 0xFFFFFFFD>>3  = 0x1FFFFFFF
// 0x028  403155B3  sra   x11, x2,  x3          x11= -3>>3          = 0xFFFFFFFF
// 0x02C  00112633  slt   x12, x2,  x1          x12= (-3 <s 7)      = 1
// 0x030  0020B6B3  sltu  x13, x1,  x2          x13= (7 <u 0xFFFFFFFD) = 1
//
// ── Section 3: I-type arithmetic (all 9) ─────────────────────────────────────
// 0x034  06400713  addi  x14, x0,  100         x14= 100  (0x64)
// 0x038  00F77793  andi  x15, x14, 0x0F        x15= 0x64 & 0x0F = 4
// 0x03C  08076813  ori   x16, x14, 0x80        x16= 0x64 | 0x80 = 0xE4
// 0x040  0FF74893  xori  x17, x14, 0xFF        x17= 0x64 ^ 0xFF = 0x9B
// 0x044  00209913  slli  x18, x1,  2           x18= 7<<2 = 28  (0x1C)
// 0x048  00415993  srli  x19, x2,  4           x19= 0xFFFFFFFD>>4 = 0x0FFFFFFF
// 0x04C  40415A13  srai  x20, x2,  4           x20= -3>>4 = -1 = 0xFFFFFFFF
// 0x050  00012A93  slti  x21, x2,  0           x21= (-3 <s 0)  = 1
// 0x054  00A0BB13  sltiu x22, x1,  10          x22= (7 <u 10)  = 1
//
// ── Section 4: LUI, AUIPC ────────────────────────────────────────────────────
// 0x058  ABCDEBB7  lui   x23, 0xABCDE          x23= 0xABCDE000
// 0x05C  00000C17  auipc x24, 0               x24= PC+0 = 0x0000005C
//
// ── Section 5: Store + Load (word) ───────────────────────────────────────────
// 0x060  00102023  sw    x1,  0(x0)            mem[0]  = 7
// 0x064  00E02223  sw    x14, 4(x0)            mem[4]  = 100
// 0x068  00002C83  lw    x25, 0(x0)            x25= 7   (load-use hazard → stall)
// 0x06C  019C8D33  add   x26, x25, x25         x26= 14  (MEM/WB→EX forwarding)
// 0x070  00402C83  lw    x25, 4(x0)            x25= 100 (0x64)
//
// ── Section 6: Branches (6 taken, 1 not-taken) ───────────────────────────────
// x28 = 0: sentinel; stays 0 if any taken branch is NOT taken.
//          incremented to 1 by not-taken fall-through.
//          incremented to 2 by JALR fall-through.
// 0x074  00000E13  addi  x28, x0,  0           x28= 0  (sentinel init)
// 0x078  00108463  beq   x1,  x1,  +8          TAKEN  (x1==x1)         → 0x080
// 0x07C  06300E13  addi  x28, x0,  99          SKIPPED
// 0x080  00209463  bne   x1,  x2,  +8          TAKEN  (7 != -3)        → 0x088
// 0x084  06300E13  addi  x28, x0,  99          SKIPPED
// 0x088  00114463  blt   x2,  x1,  +8          TAKEN  (-3 <s 7)        → 0x090
// 0x08C  06300E13  addi  x28, x0,  99          SKIPPED
// 0x090  0020D463  bge   x1,  x2,  +8          TAKEN  (7 >=s -3)       → 0x098
// 0x094  06300E13  addi  x28, x0,  99          SKIPPED
// 0x098  0020E463  bltu  x1,  x2,  +8          TAKEN  (7 <u 0xFFFFFFFD)→ 0x0A0
// 0x09C  06300E13  addi  x28, x0,  99          SKIPPED
// 0x0A0  00117463  bgeu  x2,  x1,  +8          TAKEN  (0xFFFFFFFD >=u 7)→ 0x0A8
// 0x0A4  06300E13  addi  x28, x0,  99          SKIPPED
// 0x0A8  00208463  beq   x1,  x2,  +8          NOT TAKEN (7 != -3): fall through
// 0x0AC  001E0E13  addi  x28, x28, 1           x28= 1  (not-taken path)
//
// ── Section 7: JAL ───────────────────────────────────────────────────────────
// 0x0B0  00C00EEF  jal   x29, +12             x29= 0x0B4, PC → 0x0BC
// 0x0B4  06300E13  addi  x28, x0,  99          SKIPPED (flush)
// 0x0B8  06300E13  addi  x28, x0,  99          SKIPPED (flush)
//
// ── Section 8: JALR ──────────────────────────────────────────────────────────
// 0x0BC  0CC00F13  addi  x30, x0,  0xCC        x30= 0xCC = 204
// 0x0C0  000F0FE7  jalr  x31, x30, 0           x31= 0x0C4, PC → 0x0CC
// 0x0C4  06300E13  addi  x28, x0,  99          SKIPPED (flush)
// 0x0C8  06300E13  addi  x28, x0,  99          SKIPPED (flush)
// 0x0CC  001E0E13  addi  x28, x28, 1           x28= 2  (JALR fall-through)
//
// ── Section 9: Hazard tests ───────────────────────────────────────────────────
// Test A — EX/MEM→EX forwarding (back-to-back producer/consumer)
// 0x0D0  00A00213  addi  x4,  x0,  10          x4 = 10  (producer)
// 0x0D4  00420233  add   x4,  x4,  x4          x4 = 20  (EX/MEM→EX fwd: A&B)
//
// Test B — MEM/WB→EX forwarding (one-instruction gap)
// 0x0D8  00500213  addi  x4,  x0,   5          x4 = 5   (producer)
// 0x0DC  00000013  addi  x0,  x0,   0          nop (gap)
// 0x0E0  00420233  add   x4,  x4,  x4          x4 = 10  (MEM/WB→EX fwd: A&B)
//
// Test C — load-use stall (lw immediately followed by dependent instruction)
// 0x0E4  00402023  sw    x4,  0(x0)            mem[0] = 10 (setup)
// 0x0E8  00002203  lw    x4,  0(x0)            x4 = 10  (load; triggers 1-cycle stall)
// 0x0EC  00420233  add   x4,  x4,  x4          x4 = 20  (MEM/WB→EX fwd after stall)
//
// ── Section 10: Sub-word store / load ────────────────────────────────────────
// Uses byte addresses 8–11 (word index 2, distinct from word tests at 0 and 4).
//
// Byte tests (byte addr 8, word[2] lane 0):
// 0x0F0  0AB00213  addi  x4,  x0,  0xAB        x4 = 0x000000AB
// 0x0F4  00400423  sb    x4,  8(x0)            mem[2][7:0] = 0xAB
// 0x0F8  00800283  lb    x5,  8(x0)            x5 = 0xFFFFFFAB  (sign-ext, bit7=1) FINAL
// 0x0FC  00804303  lbu   x6,  8(x0)            x6 = 0x000000AB  (zero-ext, overwritten below)
//
// Halfword tests (byte addr 10, word[2] lanes 2-3):
// 0x100  ED400213  addi  x4,  x0,  -300        x4 = 0xFFFFFED4
// 0x104  00401523  sh    x4,  10(x0)           mem[2][31:16] = 0xFED4
// 0x108  00A01203  lh    x4,  10(x0)           x4 = 0xFFFFFED4  (sign-ext, bit15=1) FINAL
// 0x10C  00A05303  lhu   x6,  10(x0)           x6 = 0x0000FED4  (zero-ext) FINAL
//
// ── Halt ─────────────────────────────────────────────────────────────────────
// 0x110  0000006F  jal   x0,  0               infinite loop  PC ∈ {0x110..0x118}
//
// ── Final expected register file ─────────────────────────────────────────────
//   x0 = 0x00000000   x1 = 0x00000007   x2 = 0xFFFFFFFD   x3 = 0x00000003
//   x4 = 0xFFFFFED4   x5 = 0xFFFFFFAB   x6 = 0x0000FED4   x7 = 0xFFFFFFFF
//   x8 = 0xFFFFFFFA   x9 = 0x00000038   x10= 0x1FFFFFFF   x11= 0xFFFFFFFF
//   x12= 0x00000001   x13= 0x00000001   x14= 0x00000064   x15= 0x00000004
//   x16= 0x000000E4   x17= 0x0000009B   x18= 0x0000001C   x19= 0x0FFFFFFF
//   x20= 0xFFFFFFFF   x21= 0x00000001   x22= 0x00000001   x23= 0xABCDE000
//   x24= 0x0000005C   x25= 0x00000064   x26= 0x0000000E   x27= 0x00000004
//   x28= 0x00000002   x29= 0x000000B4   x30= 0x000000CC   x31= 0x000000C4
